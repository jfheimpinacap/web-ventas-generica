# Django
DEBUG=true
SECRET_KEY=dev-secret-key-change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
# Solo para emergencia local, nunca habilitar en producción
CORS_ALLOW_ALL_ORIGINS=false

# Database
DATABASE_URL=

# Security headers (production defaults are secure in settings)
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
SECURE_CONTENT_TYPE_NOSNIFF=true
X_FRAME_OPTIONS=DENY
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Email
DEFAULT_FROM_EMAIL=no-reply@example.com
QUOTE_NOTIFICATION_EMAIL=vendedor@example.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
